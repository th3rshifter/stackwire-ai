{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Interview Assistant Desktop",
      "type": "debugpy",
      "request": "launch",
      "module": "app.desktop",
      "python": "${workspaceFolder}\\venv\\Scripts\\python.exe",
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal",
      "justMyCode": true
    },
    {
      "name": "Interview Assistant API",
      "type": "debugpy",
      "request": "launch",
      "module": "uvicorn",
      "python": "${workspaceFolder}\\venv\\Scripts\\python.exe",
      "args": [
        "app.main:app",
        "--host",
        "127.0.0.1",
        "--port",
        "8000",
        "--reload"
      ],
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal",
      "justMyCode": true
    }
  ]
}
