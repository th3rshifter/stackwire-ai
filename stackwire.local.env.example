SERVER_IP=#SAMPLE
SERVER_PORT=8000

# Direct remote API mode. start_client.bat sets this automatically.
# STACKWIRE_API_URL=http://SERVER_IP:8000
# STACKWIRE_API_CONNECT_TIMEOUT=5

# Local Ollama profile.
ANSWER_MODEL=qwen3.6:latest
RECOVERY_MODEL=qwen3.6:latest
FAST_RECOVERY_MODEL=qwen3.6:latest
VISION_MODEL=gemma3:4b
STACKWIRE_LLM_PROVIDER=ollama
OLLAMA_URL=http://127.0.0.1:11434/api/chat
# STACKWIRE_OPENAI_BASE_URL=http://127.0.0.1:11434/v1
# STACKWIRE_OPENAI_API_KEY=
ANSWER_MODE=normal
ANSWER_PROMPT_PROFILE=balanced
STACKWIRE_MODE=fast
RECOVERY_LOCAL_FAST_PATH=1
OLLAMA_NUM_CTX=4096
OLLAMA_RECOVERY_NUM_PREDICT=160
OLLAMA_ANSWER_NUM_PREDICT=950
OLLAMA_ARTIFACT_NUM_PREDICT=1200
OLLAMA_EXPAND_NUM_PREDICT=1200
OLLAMA_KEEP_ALIVE=30m
# OLLAMA_VISION_NUM_PREDICT=700

# Optional speech tuning:
# WHISPER_MODEL=large-v3-turbo
# WHISPER_DEVICE=auto
# WHISPER_COMPUTE_TYPE=auto
# STT_ALLOW_CPU_WHISPER_FALLBACK=1
# STT_PROBE_LOOPBACK_DEVICES=0
# STT_LOOPBACK_SIGNAL_THRESHOLD=0.00025
# STT_LIVE_MAX_WORDS=900
# STT_CONTEXT_LINES=60
# STT_LANGUAGE_MODE=auto
# WHISPER_CHUNK_SECONDS=3.5
# WHISPER_CHUNK_OVERLAP_SECONDS=1.0
# WHISPER_BEAM_SIZE=5
# WHISPER_BEST_OF=5
# WHISPER_LANGUAGE=auto
# WHISPER_VAD_FILTER=1
# WHISPER_RETRY_WITHOUT_VAD=1
# WHISPER_VAD_THRESHOLD=0.20
# WHISPER_VAD_MIN_SPEECH_MS=100
# WHISPER_VAD_MIN_SILENCE_MS=650
# WHISPER_VAD_SPEECH_PAD_MS=450
# WHISPER_NO_SPEECH_THRESHOLD=0.75
# WHISPER_LOG_PROB_THRESHOLD=-2.0
# WHISPER_COMPRESSION_RATIO_THRESHOLD=3.0
# WHISPER_REPETITION_PENALTY=1.08
# WHISPER_NO_REPEAT_NGRAM_SIZE=3
# WHISPER_HALLUCINATION_SILENCE_THRESHOLD=1.0
# STACKWIRE_AUDIO_DEVICE=Auto system audio
ANSWER_ARTIFACT_PROMPT_PROFILE=balanced

# Account / authentication (managed from Settings -> Аккаунт;).
# Login is required before chatting. Run the server (start_server.bat) so the desktop can authenticate.
# STACKWIRE_REQUIRE_AUTH=1            # set to 0 to disable the login gate entirely
# STACKWIRE_AUTH_URL=http://127.0.0.1:8000   # auth server; defaults to STACKWIRE_API_URL or local

# Local knowledge base (Qdrant + fastembed). Created automatically under data/qdrant.
# STACKWIRE_WEB_SEARCH=1             # DuckDuckGo fallback when the model is unsure
# STACKWIRE_REMEMBER_ANSWERS=1       # store answered Q/A in the local vector store
# STACKWIRE_DISABLE_VECTOR=0         # set to 1 to force the old lexical-only retrieval
# STACKWIRE_EMBED_MODEL=sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2
