SERVER_IP=#SAMPLE
SERVER_PORT=8000

# Direct remote API mode. start_client.bat sets this automatically.
# STACKWIRE_API_URL=http://SERVER_IP:8000
# STACKWIRE_API_CONNECT_TIMEOUT=5

# Fast profile: 3-6s answers on a typical local GPU/CPU setup.
# For better quality but slower answers, use qwen3.6:latest and higher token limits.
ANSWER_MODEL=qwen2.5-coder:7b
RECOVERY_MODEL=qwen3.6:latest
# VISION_MODEL=gemma4:latest
ANSWER_MODE=normal
ANSWER_PROMPT_PROFILE=compact
STACKWIRE_MODE=fast
RECOVERY_LOCAL_FAST_PATH=1
OLLAMA_NUM_CTX=4096
OLLAMA_RECOVERY_NUM_PREDICT=160
OLLAMA_ANSWER_NUM_PREDICT=900
OLLAMA_ARTIFACT_NUM_PREDICT=1200
OLLAMA_EXPAND_NUM_PREDICT=1200
OLLAMA_KEEP_ALIVE=30m
# OLLAMA_VISION_NUM_PREDICT=700

# Optional speech tuning:
# WHISPER_MODEL=large-v3-turbo
# WHISPER_DEVICE=cpu
# WHISPER_COMPUTE_TYPE=int8
# STT_ALLOW_CPU_WHISPER_FALLBACK=1
# STT_PROBE_LOOPBACK_DEVICES=0
# STT_LOOPBACK_SIGNAL_THRESHOLD=0.00025
# STT_LIVE_MAX_WORDS=900
# STT_CONTEXT_LINES=60
# WHISPER_CHUNK_SECONDS=3.5
# WHISPER_CHUNK_OVERLAP_SECONDS=1.0
# WHISPER_BEAM_SIZE=5
# WHISPER_BEST_OF=5
# WHISPER_LANGUAGE=ru
# WHISPER_VAD_FILTER=1
# WHISPER_RETRY_WITHOUT_VAD=1
# WHISPER_VAD_THRESHOLD=0.20
# WHISPER_VAD_MIN_SPEECH_MS=100
# WHISPER_VAD_MIN_SILENCE_MS=650
# WHISPER_VAD_SPEECH_PAD_MS=450
# WHISPER_NO_SPEECH_THRESHOLD=0.75
# WHISPER_LOG_PROB_THRESHOLD=-2.0
# WHISPER_COMPRESSION_RATIO_THRESHOLD=3.0
# WHISPER_REPETITION_PENALTY=1.08
# WHISPER_NO_REPEAT_NGRAM_SIZE=3
# WHISPER_HALLUCINATION_SILENCE_THRESHOLD=1.0
# STACKWIRE_UI_SCALE=0.86
# STACKWIRE_HIDE_TASKBAR=1
ANSWER_ARTIFACT_PROMPT_PROFILE=compact
