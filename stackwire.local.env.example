SERVER_IP=#SAMPLE
SERVER_PORT=#SAMPLE

# Direct remote API mode. start_client.bat sets this automatically.
# STACKWIRE_API_URL=http://SERVER_IP:8000
# STACKWIRE_API_CONNECT_TIMEOUT=5

# Optional model override. If omitted, defaults are resolved from app/llm.py and app/question_recovery.py.
# ANSWER_MODEL=qwen3.6:latest
# RECOVERY_MODEL=qwen3.6:latest
# VISION_MODEL=qwen2.5vl:7b
# ANSWER_MODE=normal
# ANSWER_MODE=deep
OLLAMA_NUM_CTX=4096
OLLAMA_RECOVERY_NUM_PREDICT=320
OLLAMA_ANSWER_NUM_PREDICT=900
# OLLAMA_VISION_NUM_PREDICT=700

# Optional:
# WHISPER_MODEL=large-v3-turbo
# WHISPER_DEVICE=cuda
# WHISPER_COMPUTE_TYPE=float16
# WHISPER_CHUNK_SECONDS=2.5
# WHISPER_BEAM_SIZE=1
# WHISPER_BEST_OF=1
# WHISPER_VAD_MIN_SILENCE_MS=300
# WHISPER_LANGUAGE=
# STACKWIRE_UI_SCALE=0.86
# STACKWIRE_HIDE_TASKBAR=1
